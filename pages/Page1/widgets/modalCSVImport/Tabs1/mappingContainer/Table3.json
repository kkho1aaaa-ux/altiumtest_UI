  "tableData": "{{\n(csvImport.state.dbFields || []).map(field => {\n\tconst mappedCsvField = csvImport.state.mapping[field.key] || '';\n\tconst firstRow = (csvImport.state.rawData || [])[0] || {};\n\tconst rawValue = mappedCsvField ? firstRow[mappedCsvField] : null;\n\tconst exampleValue = (rawValue !== undefined && rawValue !== null && rawValue !== '') \n\t? String(rawValue) \n\t: '-';\n\n\treturn {\n\t\tdb_field: field.label + (field.required ? ' *' : ''),\n\t\tdb_key: field.key,\n\t\tfield_type: field.type,\n\t\tcsv_field: mappedCsvField,\n\t\texample: exampleValue\n\t};\n})\n}}",
